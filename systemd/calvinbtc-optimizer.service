[Unit]
Description=CalvinBTC · Param Optimizer — Adaptive Parameter Tuning (Binance)
After=network.target redis.service calvinbtc-signal.service
Wants=redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/calvinbot-binance
EnvironmentFile=/opt/calvinbot-binance/.env
ExecStart=/opt/calvinbot-binance/.venv/bin/python dynamic_optimizer_binance.py
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
