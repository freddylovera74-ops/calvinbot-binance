[Unit]
Description=CalvinBTC · Signal Engine — BTC Momentum Strategy (Binance Spot)
After=network.target redis.service calvinbtc-executor.service
Wants=redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/calvinbot-binance
EnvironmentFile=/opt/calvinbot-binance/.env
ExecStart=/opt/calvinbot-binance/.venv/bin/python strategy_binance.py --real
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
